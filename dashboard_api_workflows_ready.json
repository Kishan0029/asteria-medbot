    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst input = $input.first().json;\nconst events = input.items || [];\nconst toSend = [];\n\nfor (const event of events) {\n  if (!event.start || !event.start.dateTime) continue;\n  \n  const start = new Date(event.start.dateTime);\n  const diffMs = start - now;\n  const diffHours = diffMs / (1000 * 60 * 60);\n\n  const is24hr = diffHours >= 23.5 && diffHours <= 24.5;\n  const is1hr = diffHours >= 0.5 && diffHours <= 1.5;\n\n  if (is24hr || is1hr) {\n    const desc = event.description || '';\n\n    const phone = (desc.match(/WhatsApp Number:\\s*(\\d+)/) || [])[1] || '';\n    const name = (desc.match(/Patient Name:\\s*([\\w\\s]+?)(?=WhatsApp|Date:|Clinic:|$)/) || [])[1]?.trim() || '';\n    const service = (desc.match(/Appointment Type:\\s*([\\w\\s\\/]+?)(?=Patient|WhatsApp|Date:|$)/) || [])[1]?.trim() || event.summary || '';\n\n    toSend.push({\n      json: {\n        phone,\n        name,\n        service,\n        date: start.toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: 'numeric', month: 'long', year: 'numeric' }),\n        time: start.toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit' }),\n        reminder_type: is24hr ? '24hr' : '1hr'\n      }\n    });\n  }\n}\n\nreturn toSend.length > 0 ? toSend : [{ json: { skip: true } }];"
      },
